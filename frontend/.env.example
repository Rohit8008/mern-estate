# ===========================================
# MERN Estate Client - Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit your .env.local file to version control
#
# Note: All client-side variables must be prefixed with VITE_

# ---- API Configuration ----
# Leave empty in development (uses Vite proxy)
# Set to your API URL in production
VITE_API_URL=

# ---- Socket.io Configuration ----
# Leave empty in development (defaults to localhost:3000)
# Leave empty in production (uses same origin)
# Set explicitly if your API is on a different domain
VITE_SOCKET_URL=

# ---- Error Tracking (Sentry) ----
# Sign up at https://sentry.io and get your DSN
# This is safe to include in client-side code
VITE_SENTRY_DSN=

# ---- Feature Flags ----
# Enable development dashboard (shows performance metrics)
VITE_ENABLE_DEV_DASHBOARD=false
