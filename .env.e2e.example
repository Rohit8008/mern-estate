# Copy this to .env.e2e and fill in real values before running e2e tests

# Admin credentials (must be an active admin account)
E2E_ADMIN_EMAIL=admin@yourcompany.com
E2E_ADMIN_PASSWORD=your_admin_password

# Target app URL (default: local Vite dev server)
PLAYWRIGHT_BASE_URL=http://localhost:5173

# Backend API base (default: local Express)
PLAYWRIGHT_API_URL=http://localhost:3000
